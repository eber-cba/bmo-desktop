{
  "name": "bmo-desktop",
  "version": "0.1.0",
  "description": "BMO - Virtual Desktop Pet powered by AI",
  "main": "src/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port 5174\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "electron",
    "react",
    "desktop-pet",
    "ai",
    "bmo"
  ],
  "author": "Eber",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "eslint": "^9.17.0",
    "vite": "^6.0.6",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
