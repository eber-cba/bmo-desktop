# BMO Desktop Pet - Configuración de Variables de Entorno

# Motor de IA a usar ('ollama' o 'openai')
AI_PROVIDER=ollama

# Modelo a usar (ej: 'llama3', 'mistral', 'phi3' para ollama)
AI_MODEL=llama3

# URL local de Ollama (por defecto es 11434)
OLLAMA_BASE_URL=http://localhost:11434

# Si usas OpenAI, pon tu API Key aquí
OPENAI_API_KEY=tu_api_key_aqui
