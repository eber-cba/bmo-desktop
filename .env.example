# Variables de entorno — copiar como `.env` y completar con valores reales
# El archivo `.env` NUNCA se sube a git

# ─── Proveedor de IA ───────────────────────────────
# Opciones: "ollama" | "openai"
AI_PROVIDER=ollama

# Modelo a usar (según proveedor)
# Ollama: llama3, mistral, gemma
# OpenAI: gpt-4o-mini, gpt-4o
AI_MODEL=llama3

# ─── Ollama (IA local, sin costo) ─────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── OpenAI (opcional, cloud) ─────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─── App ───────────────────────────────────────────
NODE_ENV=development
